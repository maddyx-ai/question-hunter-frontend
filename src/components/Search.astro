---
// Search.astro
---
<div id="search-modal" class="fixed inset-0 z-50 hidden bg-canvas-night/80 backdrop-blur-sm flex items-start justify-center pt-[15vh] px-4 opacity-0 transition-opacity duration-200" aria-hidden="true">
  <div class="bg-canvas-night border border-white/10 shadow-[0_20px_50px_rgba(0,0,0,0.7)] rounded-xl w-full max-w-2xl overflow-hidden" id="search-container">
    <div class="p-4 border-b border-white/10 flex justify-between items-center bg-white/5">
      <span class="text-sm text-ink-mute font-medium">Search</span>
      <button id="close-search" class="text-ink-mute hover:text-on-dark transition-colors" aria-label="Close search">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>
    </div>
    <div class="p-6 max-h-[60vh] overflow-y-auto">
      <div id="search"></div>
    </div>
  </div>
</div>

<link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
<script src="/pagefind/pagefind-ui.js" is:inline></script>

<style is:global>
  /* Override Pagefind's default styling to match our anti-gravity theme */
  :root {
    --pagefind-ui-scale: 1;
    --pagefind-ui-primary: var(--color-primary);
    --pagefind-ui-text: var(--color-ink);
    --pagefind-ui-background: transparent;
    --pagefind-ui-border: rgba(255, 255, 255, 0.1);
    --pagefind-ui-tag: rgba(62, 207, 142, 0.1);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: var(--radius-sm);
    --pagefind-ui-font: var(--font-sans);
  }

  .pagefind-ui__search-input {
    color: var(--color-on-dark) !important;
    background-color: rgba(255, 255, 255, 0.05) !important;
    font-weight: 400 !important;
  }
  
  .pagefind-ui__search-clear {
    background-color: transparent !important;
  }

  .pagefind-ui__result-link {
    color: var(--color-on-dark) !important;
  }

  .pagefind-ui__result-excerpt {
    color: var(--color-ink-mute) !important;
  }
  
  .pagefind-ui__message {
    color: var(--color-ink-mute) !important;
  }

  .pagefind-ui__button {
    background-color: rgba(255, 255, 255, 0.05) !important;
    color: var(--color-ink-mute) !important;
    border: 1px solid rgba(255, 255, 255, 0.1) !important;
  }

  .pagefind-ui__button:hover {
    background-color: rgba(255, 255, 255, 0.1) !important;
    color: var(--color-on-dark) !important;
  }
</style>

<script is:inline>
  window.addEventListener('DOMContentLoaded', () => {
    // Initialize Pagefind UI
    if (typeof PagefindUI !== 'undefined') {
      new PagefindUI({ element: "#search", showSubResults: true, showImages: false });
    }

    const modal = document.getElementById('search-modal');
    const closeBtn = document.getElementById('close-search');
    const triggers = document.querySelectorAll('[data-search-trigger]');
    
    function openSearch() {
      modal.classList.remove('hidden');
      modal.setAttribute('aria-hidden', 'false');
      // trigger reflow
      void modal.offsetWidth;
      modal.classList.remove('opacity-0');
      modal.classList.add('opacity-100');
      
      // Focus input after transition
      setTimeout(() => {
        const input = document.querySelector('.pagefind-ui__search-input');
        if (input) input.focus();
      }, 100);
    }
    
    function closeSearch() {
      modal.classList.remove('opacity-100');
      modal.classList.add('opacity-0');
      modal.setAttribute('aria-hidden', 'true');
      setTimeout(() => {
        modal.classList.add('hidden');
      }, 200);
    }

    // Event Listeners
    triggers.forEach(trigger => {
      trigger.addEventListener('click', (e) => {
        e.preventDefault();
        openSearch();
      });
    });

    if (closeBtn) {
      closeBtn.addEventListener('click', closeSearch);
    }

    if (modal) {
      modal.addEventListener('click', (e) => {
        if (e.target === modal) {
          closeSearch();
        }
      });
    }

    window.addEventListener('keydown', (e) => {
      // Cmd+K or Ctrl+K
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        if (modal.classList.contains('hidden')) {
          openSearch();
        } else {
          closeSearch();
        }
      }
      // Escape
      if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
        closeSearch();
      }
    });
  });
</script>
